# =============================================
# CONFIGURACIÓN DEL AGENTE - RESTAURANTE JAPONÉS
# =============================================

# --- Groq (100% gratis en console.groq.com) ---
GROQ_API_KEY=gsk_...tu_key_aqui

# --- WhatsApp (Meta Cloud API) ---
WHATSAPP_TOKEN=tu_token_de_meta_aqui
WHATSAPP_PHONE_ID=tu_phone_number_id
WHATSAPP_VERIFY_TOKEN=una_palabra_secreta_que_tu_eliges

# --- Servidor ---
PORT=3000
NODE_ENV=development

# --- Tu sistema de pedidos (opcional por ahora) ---
SISTEMA_PEDIDOS_URL=http://tu-sistema.com/api
SISTEMA_PEDIDOS_TOKEN=token_de_tu_sistema

# --- Twilio (llamadas telefónicas) ---
# Obtén en: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+521234567890

# --- Deepgram (voz a texto, gratis con $200 crédito) ---
# Obtén en: https://console.deepgram.com
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- URL pública del servidor (Railway, Render, etc.) ---
BASE_URL=https://tu-agente.railway.app
